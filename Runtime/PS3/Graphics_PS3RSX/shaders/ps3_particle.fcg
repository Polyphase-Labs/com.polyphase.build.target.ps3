// PS3/RSX particle fragment program — modulate the sprite texture by the
// per-vertex colour (tint + fade) and a material tint uniform. Untextured
// particle systems bind the 1x1 white texel so the multiply is a no-op.
void main
(
	float2 texcoord : TEXCOORD0,
	float4 color    : TEXCOORD1,

	uniform sampler2D texture,
	uniform float4    tint,

	out float4 oColor
)
{
	oColor = tex2D(texture, texcoord) * color * tint;
}
